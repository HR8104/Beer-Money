# Django Secret Key
SECRET_KEY=your-django-secret-key-here
DEBUG=True

# PythonAnywhere MySQL Database Configuration
# You must initialize your database in the PythonAnywhere 'Databases' tab first.
# Format: DATABASE_URL=mysql://username:password@username.mysql.pythonanywhere-services.com/username$dbname
DATABASE_URL=mysql://[YOUR-USERNAME]:[YOUR-DB-PASSWORD]@[YOUR-USERNAME].mysql.pythonanywhere-services.com/[YOUR-USERNAME]$[YOUR-DB-NAME]

# Keep these if you configure DATABASES using individual variables in settings.py instead of URL
DB_NAME=[YOUR-USERNAME]$[YOUR-DB-NAME]
DB_USER=[YOUR-USERNAME]
DB_PASSWORD=your-db-password-here
DB_HOST=[YOUR-USERNAME].mysql.pythonanywhere-services.com
DB_PORT=3306
# Other existing variables
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
ADMIN_EMAILS=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
TELEGRAM_BOT_USERNAME=
