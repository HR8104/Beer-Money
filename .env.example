# Django Secret Key
SECRET_KEY=your-django-secret-key-here
DEBUG=True

# Hosts and CSRF
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# Supabase PostgreSQL Configuration
# You can use the Direct Connection or Transaction Pooler URL
# Format: DATABASE_URL=postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST]:5432/postgres

# Alternatively, set individual variables
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-password-here
DB_HOST=your-supabase-host-here
DB_PORT=5432

# Email
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Access control
ADMIN_EMAILS=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# Transport and cookie security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin

# OTP throttling and lockout
OTP_EXPIRY_MINUTES=5
OTP_SEND_RATE_LIMIT=5
OTP_VERIFY_RATE_LIMIT=10
OTP_RESEND_RATE_LIMIT=5
OTP_RATE_LIMIT_WINDOW_SECONDS=900
OTP_VERIFY_MAX_FAILURES=5
OTP_VERIFY_LOCKOUT_SECONDS=900
OTP_LOG_TO_CONSOLE_FOR_TESTING=True

# Security monitoring
SECURITY_LOG_LEVEL=INFO
SECURITY_ALERT_EMAILS=
SECURITY_MIRROR_TO_ADMIN_LOGS=True
